<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToWidth="true"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.luisdbb.tarea3AD2024base.controller.RegistrarPersonaController"
            stylesheets="@/styles/Styles.css">

    <content>

        <VBox alignment="CENTER">

            <VBox spacing="15" alignment="CENTER"
                  styleClass="card"
                  maxWidth="450">

                <padding>
                    <Insets top="20" right="20" bottom="20" left="20"/>
                </padding>


                <Label text="Registrar Persona"
                       styleClass="title"/>

                <TextField fx:id="nombreField"
                           promptText="Nombre real"
                           prefWidth="250"/>

                <TextField fx:id="emailField"
                           promptText="Email"
                           prefWidth="250"/>

                <TextField fx:id="nacionalidadField"
                           promptText="Nacionalidad"
                           prefWidth="250"/>

                <ComboBox fx:id="tipoPersonaCombo"
                          promptText="Tipo de persona"
                          prefWidth="250"/>

                <TextField fx:id="apodoField"
                           promptText="Apodo (solo artista)"
                           prefWidth="250"/>

                <Label text="Especialidades (solo artista)"/>

                <VBox fx:id="especialidadesBox" spacing="5" alignment="CENTER_LEFT">
                    <CheckBox text="ACROBACIA"/>
                    <CheckBox text="HUMOR"/>
                    <CheckBox text="MAGIA"/>
                    <CheckBox text="EQUILIBRISMO"/>
                    <CheckBox text="MALABARISMO"/>
                </VBox>

                <Label text="Coordinación"/>

                <HBox spacing="10" alignment="CENTER">
                    <CheckBox fx:id="seniorCheck" text="Senior"/>
                    <DatePicker fx:id="fechaSeniorPicker"/>
                </HBox>

                <Label text="Credenciales"/>

                <TextField fx:id="usernameField"
                           promptText="Username"
                           prefWidth="250"/>

                <PasswordField fx:id="passwordField"
                               promptText="Password"
                               prefWidth="250"/>

                <HBox spacing="10" alignment="CENTER">
                    <Button text="Registrar"
                            onAction="#registrarPersona"
                            styleClass="button btn-admin"
                            prefWidth="120"/>

                    <Button text="Volver"
                            onAction="#volver"
                            styleClass="button btn-invitado"
                            prefWidth="120"/>
                </HBox>

            </VBox>

        </VBox>

    </content>

</ScrollPane>