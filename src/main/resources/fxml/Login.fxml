<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20" alignment="CENTER"
      prefWidth="600.0" prefHeight="400.0"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.luisdbb.tarea3AD2024base.controller.LoginController"
      stylesheets="@/styles/Styles.css">

    <padding>
        <Insets top="40" right="40" bottom="40" left="40"/>
    </padding>

    <VBox styleClass="card" spacing="20" alignment="CENTER" maxWidth="400">

        <Label text="Sistema de Gestión del Circo"
               styleClass="title"/>

        <GridPane hgap="15" vgap="15" alignment="CENTER">

            <Label text="Usuario:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>

            <TextField fx:id="usernameField"
                       promptText="Introduce tu usuario"
                       prefWidth="250"
                       GridPane.rowIndex="0"
                       GridPane.columnIndex="1"/>

            <Label text="Contraseña:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>

            <StackPane GridPane.rowIndex="1" GridPane.columnIndex="1">

                <PasswordField fx:id="passwordField"
                               promptText="Introduce tu contraseña"
                               prefWidth="250"/>

                <TextField fx:id="passwordVisible"
                           promptText="Introduce tu contraseña"
                           prefWidth="250"
                           visible="false"/>

            </StackPane>

        </GridPane>

        <CheckBox fx:id="mostrarPassword"
                  text="Mostrar contraseña"
                  onAction="#mostrarPassword"/>

        <HBox spacing="15" alignment="CENTER">

            <Button text="Iniciar sesión"
                    onAction="#login"
                    styleClass="button btn-artista"/>

            <Button text="Recuperar contraseña"
                    onAction="#recuperarPassword"
                    styleClass="button btn-coord"/>

        </HBox>

        <Button text="Ver espectáculos como invitado"
                onAction="#entrarInvitado"
                styleClass="button btn-invitado"/>

    </VBox>

</VBox>