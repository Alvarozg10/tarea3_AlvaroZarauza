<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToWidth="true"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.luisdbb.tarea3AD2024base.controller.ModificarNumeroController"
            stylesheets="@/styles/Styles.css">

    <content>

        <VBox alignment="CENTER">

            <VBox spacing="15"
                  alignment="CENTER"
                  styleClass="card"
                  maxWidth="500">

                <padding>
                    <Insets top="20"
                            right="20"
                            bottom="20"
                            left="20"/>
                </padding>

                <Label text="Modificar Número"
                       styleClass="title"/>

                <TableView fx:id="numerosTable"
                           prefHeight="200"
                           prefWidth="450">

                    <columns>

                        <TableColumn fx:id="nombreColumn"
                                     text="Nombre"
                                     prefWidth="180"/>

                        <TableColumn fx:id="duracionColumn"
                                     text="Duración"
                                     prefWidth="120"/>

                        <TableColumn fx:id="ordenColumn"
                                     text="Orden"
                                     prefWidth="120"/>

                    </columns>

                </TableView>

                <Button text="Cargar número"
                        onAction="#cargarNumero"
                        styleClass="button btn-coord"
                        prefWidth="160"/>

                <TextField fx:id="nombreField"
                           promptText="Nombre"
                           prefWidth="250"/>

                <TextField fx:id="duracionField"
                           promptText="Duración (1.0 / 1.5)"
                           prefWidth="250"/>

                <TextField fx:id="ordenField"
                           promptText="Orden"
                           prefWidth="250"/>

                <Label text="Seleccionar artistas"/>

                <ListView fx:id="artistasList"
                          prefHeight="200"
                          prefWidth="250"
                          VBox.vgrow="ALWAYS"/>

                <HBox spacing="10"
                       alignment="CENTER">

                    <Button text="Guardar cambios"
                            onAction="#guardarCambios"
                            styleClass="button btn-coord"
                            prefWidth="150"/>

                    <Button text="Volver"
                            onAction="#volver"
                            styleClass="button btn-invitado"
                            prefWidth="120"/>

                </HBox>

            </VBox>

        </VBox>

    </content>

</ScrollPane>